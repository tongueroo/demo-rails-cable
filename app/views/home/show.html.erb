<div class="w-full max-w-3xl mx-auto space-y-8">
  <div class="space-y-3">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700">Blossom Demo</p>
    <h1 class="text-5xl font-black tracking-tight text-slate-900">Standalone Cable Heartbeat</h1>
    <p class="text-lg text-slate-600">
      This page subscribes over <code>/cable</code> and updates live every few seconds.
    </p>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/70">
    <%= turbo_stream_from HeartbeatPresenter::CHANNEL %>
    <%= render "heartbeat", heartbeat: @heartbeat %>
  </div>

  <div class="rounded-2xl bg-slate-950 px-6 py-5 text-sm text-slate-100">
    <p class="font-semibold text-emerald-300">Procfile</p>
    <pre class="mt-3 overflow-x-auto"><code>web: bin/rails server -p $PORT
cable: bin/cable
jobs: bin/jobs</code></pre>
  </div>
</div>
